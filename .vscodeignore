# 🚀 Ignore Node.js dependencies entirely (We are using esbuild now!)
node_modules/**

# 🚀 Ignore Heavy Python Environments & Cache
.venv/**
echo_venv/**
__pycache__/**
**/*.pyc

# 🚀 Ignore unbundled source code (We only need the 'dist' folder and copied assets)
Core/**/*.js
program_features/**/*.js
navigation_features/**/*.js
Language/**/*.js
extension.js
copy-assets.js

# 🚀 Ignore Git metadata
.git/**
.gitignore

# 🚀 Ignore VSIX build artifacts
*.vsix

# 🚀 Ignore test-related files
.vscode-test/**
test/**

# 🚀 Ignore temporary or cache files
**/*.map
**/.vscode-test.*

# 🚀 Ignore unnecessary config files
jsconfig.json
tsconfig.json